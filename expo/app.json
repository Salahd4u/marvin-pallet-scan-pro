{
  "expo": {
    "name": "WindowCheck",
    "slug": "fvg5036etypiewht0qx08",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.fvg5036etypiewht0qx08",
      "infoPlist": {
        "NSCameraUsageDescription": "WindowCheck uses the camera to capture window photos for quality inspection.",
        "NSPhotoLibraryUsageDescription": "WindowCheck accesses your photo library so you can select window images for inspection."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0F14"
      },
      "package": "app.rork.fvg5036etypiewht0qx08",
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "WindowCheck accesses your photo library so you can select window images for inspection.",
          "cameraPermission": "WindowCheck uses the camera to capture window photos for quality inspection."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
